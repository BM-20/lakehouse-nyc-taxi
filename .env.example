# Copy this to .env and adjust. `docker compose` reads .env automatically.
#   cp .env.example .env

# User id Airflow runs as inside the containers, so files written to the mounted
# volumes (airflow/logs, data/, catalog/) are owned by you. On macOS the default
# 50000 is usually fine; on Linux set it to your uid:
#   echo "AIRFLOW_UID=$(id -u)" >> .env
AIRFLOW_UID=50000

# Set to false to skip the dbt run/test tasks (e.g. if BigQuery isn't configured
# in the container yet). The bronze -> silver -> gold pipeline still runs.
RUN_DBT=true
